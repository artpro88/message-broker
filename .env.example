# Server
PORT=3000
NODE_ENV=development
INSTANCE_NAME=default

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=message_broker
DB_USER=postgres
DB_PASSWORD=password

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=support@company.com
EMAIL_PASSWORD=your_password
EMAIL_FROM=support@company.com

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=24h

# Live Chat
LIVECHAT_ENABLED=true
LIVECHAT_GREETING=Hello! How can we help you today?

# Customer Data API
CUSTOMER_API_URL=https://api.example.com
CUSTOMER_API_KEY=your_api_key

# Snowflake (optional)
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema

